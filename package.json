{
  "name": "oriondino",
  "version": "1.0.0",
  "description": "Orion & Yamin — Corrida da Aventura (Android APK)",
  "scripts": {
    "build": "echo 'Static project — no build step needed'",
    "cap:init": "cap init",
    "cap:add:android": "cap add android",
    "cap:sync": "cap sync",
    "cap:open": "cap open android",
    "apk:debug": "cap sync && cd android && ./gradlew assembleDebug",
    "apk:release": "cap sync && cd android && ./gradlew assembleRelease"
  },
  "dependencies": {
    "@capacitor/android": "^6.0.0",
    "@capacitor/core": "^6.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0"
  }
}
